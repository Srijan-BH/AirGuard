# Core Configuration
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=YOUR_FLASK_SECRET_KEY_HERE

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/airguard_db?retryWrites=true&w=majority

# Security
JWT_SECRET_KEY=YOUR_JWT_SECRET_KEY_HERE

# API Keys
OPENWEATHER_API_KEY=YOUR_OPENWEATHER_API_KEY_HERE

# Email Alert System (SMTP)
SMTP_EMAIL=YOUR_SMTP_EMAIL_HERE
SMTP_PASSWORD=YOUR_SMTP_PASSWORD_HERE

# Twilio SMS Alerts
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN_HERE
TWILIO_PHONE_NUMBER=YOUR_TWILIO_PHONE_HERE

SUBSCRIBED_PHONE_NUMBERS=YOUR_PHONE_NUMBER_HERE
